flowchart LR
    %% Actors
    Patient(("Patient"))
    Doctor(("Doctor"))
    Pharmacist(("Pharmacist"))
    Admin(("Admin"))

    %% System Boundary
    subgraph App[RespiriCare App]
        %% Common Use Cases
        UC_Auth([Authentication & Registration])
        UC_Profile([Manage Profile & Settings])
        UC_Chat([Chat & Messaging])
        UC_Notify([View Notifications])

        %% Patient Use Cases
        UC_Patient1([Request Video Consultation])
        UC_Patient2([View Medications & Reminders])
        UC_Patient3([Log Symptoms & Track History])
        UC_Patient4([View Prescriptions])

        %% Doctor Use Cases
        UC_Doctor1([Manage Consultations & Video Calls])
        UC_Doctor2([View Patients & Analytics Reports])
        UC_Doctor3([Create & Issue Digital Prescriptions])

        %% Pharmacist Use Cases
        UC_Pharm1([Manage Drug Inventory & Directory])
        UC_Pharm2([Verify Custom Drugs])
        UC_Pharm3([Monitor Missed Medications & Alerts])
        UC_Pharm4([View All Pending Prescriptions])
        
        %% Admin Use Cases
        UC_Admin1([Manage Users & Roles])
    end

    %% Patient Relationships
    Patient --> UC_Auth
    Patient --> UC_Profile
    Patient --> UC_Patient1
    Patient --> UC_Patient2
    Patient --> UC_Patient3
    Patient --> UC_Patient4
    Patient --> UC_Chat
    Patient --> UC_Notify

    %% Doctor Relationships
    Doctor --> UC_Auth
    Doctor --> UC_Profile
    Doctor --> UC_Doctor1
    Doctor --> UC_Doctor2
    Doctor --> UC_Doctor3
    Doctor --> UC_Chat
    Doctor --> UC_Notify

    %% Pharmacist Relationships
    Pharmacist --> UC_Auth
    Pharmacist --> UC_Profile
    Pharmacist --> UC_Pharm1
    Pharmacist --> UC_Pharm2
    Pharmacist --> UC_Pharm3
    Pharmacist --> UC_Pharm4
    Pharmacist --> UC_Chat
    Pharmacist --> UC_Notify

    %% Admin Relationships
    Admin --> UC_Auth
    Admin --> UC_Admin1

    %% Note styling classes
    classDef actor fill:#e1f5fe,stroke:#0288d1,stroke-width:2px
    classDef usecase fill:#ffffff,stroke:#333333,stroke-width:1px,rx:15,ry:15
    
    class Patient,Doctor,Pharmacist,Admin actor
    class UC_Auth,UC_Profile,UC_Chat,UC_Notify,UC_Patient1,UC_Patient2,UC_Patient3,UC_Patient4,UC_Doctor1,UC_Doctor2,UC_Doctor3,UC_Pharm1,UC_Pharm2,UC_Pharm3,UC_Pharm4,UC_Admin1 usecase
